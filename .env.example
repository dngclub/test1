# ez2AI Builder 자식 프로젝트 환경 변수
# 본 파일을 .env 로 복사하여 사용하세요.
#
# ⚠️ SECRET_KEY / JWT_ALGORITHM 은 본 .env 에 작성하지 마세요.
#    본체 빌더 환경 운영에서 시작할 때 env_manager 가 자동 주입합니다 (메모리에서만 전달).

# ── ez2ai 본 서버 연결 (자식 frontend 의 vite proxy 가 사용) ──
EZ2AI_BASE_URL=http://localhost:8000

# ── 자식 자체 DB ──
# 본체와 같은 DB 인스턴스의 다른 스키마 권장. 미설정 시 env_manager 가 본체 DATABASE_URL fallback 주입.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/your_db

# ── 빌더 환경 운영이 자식 SDK 로 본체 ai_proxy 호출 시 사용 (선택) ──
EZ2AI_BUILDER_API_KEY=
